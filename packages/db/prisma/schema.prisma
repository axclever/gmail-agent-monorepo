generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum MailboxProvider {
  GMAIL
}

enum MailboxStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum RecipientType {
  TO
  CC
  BCC
}

enum ClassificationKind {
  CATEGORY
  INTENT
  PRIORITY
  REPLY_NEEDED
  MESSAGE_TYPE
}

enum IntegrationType {
  HTTP
  SMTP
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)

  accounts Account[]
  sessions Session[]

  gmailMailboxes GmailMailbox[]
  integrations   Integration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Integration {
  id                  String          @id @default(cuid())
  userId              String
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                IntegrationType
  name                String
  isActive            Boolean         @default(true)
  /// Non-secret settings only (URLs, ports, default chat id, etc.).
  configJson          Json?
  /// Application-layer encrypted payload (tokens, passwords, API keys).
  encryptedSecretJson Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  gmailActions GmailAction[]

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Person {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  firstSeenAt DateTime?
  lastSeenAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sentMessages     GmailMessage[]          @relation("MessageFromPerson")
  receivedMessages GmailMessageRecipient[]

  @@index([email])
}

model GmailMailbox {
  id       String          @id @default(cuid())
  userId   String
  provider MailboxProvider @default(GMAIL)
  status   MailboxStatus   @default(ACTIVE)

  /// Email address of the connected Gmail inbox
  email           String
  /// Lowercased send-as / alias addresses from Gmail (users.settings.sendAs); refreshed on connect and each sync.
  sendAsEmails    String[] @default([])
  googleAccountId String?

  /// Tokens for mailbox access, separate from app auth if needed
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?

  /// Gmail incremental sync cursor
  lastHistoryId String?
  lastSyncedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  threads   GmailThread[]
  messages  GmailMessage[]
  syncRuns  GmailSyncRun[]
  rules     GmailRule[]
  decisions GmailDecision[]

  @@unique([userId, email])
  @@index([userId])
  @@index([status])
}

model GmailThread {
  id                   String            @id @default(cuid())
  mailboxId            String
  gmailThreadId        String
  subject              String?
  snippet              String?
  summary              String?
  /// When derived thread summary (and related fields) were last refreshed in the agent.
  lastSummarizedAt     DateTime?
  lastIntent           String?
  priority             String?
  replyRequired        Boolean?
  waitingOnOtherParty  Boolean?
  status               String?
  messageCount         Int               @default(0)
  lastMessageAt        DateTime?
  lastMessageDirection MessageDirection?
  lastInboundAt        DateTime?
  lastOutboundAt       DateTime?
  hasUnrepliedInbound  Boolean?          @default(false)
  /// Derived processing state; for MVP this mirrors replyRequired.
  actionRequired       Boolean?
  needsEvaluation      Boolean           @default(false)
  lastEvaluatedAt      DateTime?
  lastDecisionAt       DateTime?
  /// LLM thread-level analysis (summary, currentIntent, stage, needsReply, waitingOn); refreshed on new inbound.
  threadAnalysisJson   Json?
  threadAnalysisAt     DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  mailbox         GmailMailbox                @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  messages        GmailMessage[]
  classifications GmailThreadClassification[]
  decisions       GmailDecision[]

  @@unique([mailboxId, gmailThreadId])
  @@index([mailboxId])
  @@index([lastMessageAt])
  @@index([status])
  @@index([replyRequired])
  @@index([needsEvaluation])
  @@index([hasUnrepliedInbound])
}

model GmailMessage {
  id                String    @id @default(cuid())
  mailboxId         String
  threadId          String
  gmailMessageId    String
  gmailInternalDate DateTime?

  direction MessageDirection
  subject   String?
  snippet   String?
  textBody  String?
  htmlBody  String?

  fromPersonId String?

  isRead         Boolean?
  isStarred      Boolean?
  hasAttachments Boolean  @default(false)

  internetMessageId String?
  inReplyTo         String?
  references        String?

  /// raw Gmail data for future reprocessing/debugging
  headersJson          Json?
  labelIdsJson         Json?
  rawPayloadJson       Json?
  classificationStatus String?
  classifiedAt         DateTime?
  templateKey          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mailbox    GmailMailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  thread     GmailThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  fromPerson Person?      @relation("MessageFromPerson", fields: [fromPersonId], references: [id], onDelete: SetNull)

  recipients      GmailMessageRecipient[]
  classifications GmailMessageClassification[]
  decisions       GmailDecision[]

  @@unique([mailboxId, gmailMessageId])
  @@index([mailboxId])
  @@index([threadId])
  @@index([fromPersonId])
  @@index([gmailInternalDate])
  @@index([direction])
}

model GmailMessageRecipient {
  id        String        @id @default(cuid())
  messageId String
  personId  String
  type      RecipientType

  createdAt DateTime @default(now())

  message GmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  person  Person       @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([messageId, personId, type])
  @@index([messageId])
  @@index([personId])
  @@index([type])
}

model GmailMessageClassification {
  id         String             @id @default(cuid())
  messageId  String
  kind       ClassificationKind
  value      String
  confidence Float?
  model      String?
  rawJson    Json?
  createdAt  DateTime           @default(now())

  message GmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([kind])
  @@index([value])
}

model GmailThreadClassification {
  id         String             @id @default(cuid())
  threadId   String
  kind       ClassificationKind
  value      String
  confidence Float?
  model      String?
  rawJson    Json?
  createdAt  DateTime           @default(now())

  thread GmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([kind])
  @@index([value])
}

model GmailSyncRun {
  id           String    @id @default(cuid())
  mailboxId    String
  status       String
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  fetchedCount Int       @default(0)
  newCount     Int       @default(0)
  updatedCount Int       @default(0)
  errorText    String?

  mailbox GmailMailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  @@index([mailboxId])
  @@index([startedAt])
  @@index([status])
}

model GmailRule {
  id               String   @id @default(cuid())
  mailboxId        String
  name             String
  priority         Int      @default(100)
  isActive         Boolean  @default(true)
  conditionsJson   Json?
  actionType       String
  actionConfigJson Json?
  stopProcessing   Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mailbox   GmailMailbox    @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  decisions GmailDecision[]

  @@index([mailboxId])
  @@index([isActive])
  @@index([priority])
}

model GmailDecision {
  id           String   @id @default(cuid())
  mailboxId    String
  threadId     String
  messageId    String?
  ruleId       String?
  decisionType String
  status       String
  reason       String?
  createdAt    DateTime @default(now())

  mailbox GmailMailbox  @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  thread  GmailThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message GmailMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  rule    GmailRule?    @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  actions GmailAction[]

  @@index([mailboxId])
  @@index([threadId])
  @@index([messageId])
  @@index([ruleId])
  @@index([status])
}

model GmailAction {
  id            String    @id @default(cuid())
  decisionId    String
  integrationId String?
  type          String
  status        String
  payloadJson   Json?
  resultJson    Json?
  errorText     String?
  executedAt    DateTime?
  createdAt     DateTime  @default(now())

  decision    GmailDecision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  integration Integration?  @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([decisionId])
  @@index([integrationId])
  @@index([status])
  @@index([type])
}
