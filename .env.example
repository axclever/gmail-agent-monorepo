# Рантайм (Next.js, Lambda): через PgBouncer — transaction pooling.
# Добавьте &pgbouncer=true если пулер в transaction mode (рекомендуется Prisma).
DATABASE_URL="postgresql://USER:PASSWORD@pgbouncer-host:6432/DATABASE?schema=public&pgbouncer=true"

# Миграции / prisma migrate / db push — прямое подключение к PostgreSQL (минуя PgBouncer).
DIRECT_URL="postgresql://USER:PASSWORD@postgres-host:5432/DATABASE?schema=public"

# Локально без PgBouncer можно указать один и тот же URL в обеих переменных.
